<odoo>
    <record id="bm_hr_employee_form" model="ir.ui.view">
        <field name="name">bm.hr.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">
            <field name="address_id" position="before">
                <field name="work_contact_id" readonly="1" force_save="1" />
            </field>
            <field name="private_phone" position="after">
                <field name="private_signature" widget="image" groups="base.group_system" options="{'size': [150, 150]}" />
            </field>
        </field>
    </record>

    <record id="bm_res_users_view_form_profile" model="ir.ui.view">
        <field name="name">bm.res.users.view.form.profile</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="hr.res_users_view_form_profile" />
        <field name="arch" type="xml">
            <field name="private_phone" position="after">
                <field name="private_signature" widget="image" options="{'size': [150, 150]}" />
            </field>
        </field>
    </record>

    
</odoo>