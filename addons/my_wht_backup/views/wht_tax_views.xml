<odoo>
    <record id="view_wht_tax_tree" model="ir.ui.view">
        <field name="name">wht.tax.tree</field>
        <field name="model">wht.tax</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="rate"/>
                <field name="type"/>
                <field name="income_type"/>
                <field name="partner_type"/>
            </tree>
        </field>
    </record>

    <record id="view_wht_tax_form" model="ir.ui.view">
        <field name="name">wht.tax.form</field>
        <field name="model">wht.tax</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="rate"/>
                        <field name="type"/>
                        <field name="income_type"/>
                        <field name="partner_type"/>
                        <field name="account_id"/>
                        <field name="company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>