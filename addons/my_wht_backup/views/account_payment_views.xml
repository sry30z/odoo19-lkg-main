<odoo>
    <record id="view_account_payment_form_inherit_wht" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.wht</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <sheet position="inside">
                <group string="Withholding Tax">
                    <field name="wht_id"/>
                    <field name="wht_amount" readonly="1"/>
                </group>
            </sheet>
        </field>
    </record>
</odoo>