<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_WHT.view_account_payment_form" model="ir.ui.view">
            <field name="name">account_wht view_account_payment_form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_wht_certificates" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="wht_certificate_count == 0">
                        <field name="wht_certificate_count" widget="statinfo" string="WHT Certificates"/>
                    </button>
                </xpath>
                <field name="amount" invisible="move_id != False"/>

                <field name="currency_id" invisible="move_id != False" />


                <xpath expr="//field[@name='date']" position="before">
                    <field name="move_id"
                           invisible="1"/>
                    <field name="payment_amount"
                           force_save="1"
                           readonly="state !=  'draft'"
                           invisible="move_id ==  False"/>
                    <field name="override_wht"
                           force_save="1"
                           invisible="1"
                           readonly="state !=  'draft'"/>
                    <field name="wht_type" string="WHT" invisible="not wht_type" readonly="1" force_save="1" />
                    <field name="wht_ids" string="WHT Details"
                           force_save="1"
                           readonly="state !=  'draft'"
                           invisible="payment_type not in  ('inbound', 'outbound')"
                           widget="many2many_tags"
                           options="{'no_create': True}"/>

                    <field name="wht_amount" string="WHT Amount" readonly="1" force_save="1"/>
                    <field name="amount"
                           string="Net Amount"
                           readonly="state !=  'draft'"
                           invisible="move_id ==  False"/>


                    <field name="after_wh_payment_amount" invisible="0"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>