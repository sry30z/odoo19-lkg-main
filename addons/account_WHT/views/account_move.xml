<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="invoice_form_inherit_for_withholding_tax" model="ir.ui.view">
            <field name="name">account.invoice.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">
                <!-- Removed domain to allow both sale/purchase WHT selection -->
                <xpath expr="//field[@name='invoice_line_ids']//field[@name='tax_ids']" position="after">
                    <field name="wht_id" options="{'no_create': True}" optional="show"/>
                    <field name="wht_tax_ids" widget="many2many_tags" options="{'no_create': True}" optional="hide" force_save="1" />
                    <field name="wht_amount" optional="hide"/>
                    <field name="is_wht_line" invisible="1" />
                </xpath>

                <!-- Removed obsolete tax_line_ids xpath which caused empty Taxes table in Odoo 18 -->
                <xpath expr="//notebook" position="inside">
                    <page name="wht_info" string="WHT Info" invisible="1">
                        <field name="wht_line_ids">
                            <list string="WHT Tree">
                                <field name="move_id" invisible="1" />
                                <field name="name" />
                                <field name="account_id" />
                                <field name="amount" />
                            </list>
                        </field>
                    </page>
                </xpath>
                <!--                Adding taxes tree view on move form -->
                <xpath expr="//page[@name='invoice_tab']/field[@name='invoice_line_ids']" position="after">
                    <div>
                        <h4>WITHHOLDING TAX</h4>
                        <div class="oe_inline">
                            <field name="taxes_line_ids" readonly="1" force_save="1">
                                <list string="Taxes" editable="bottom">
                                    <field name="name" />
                                    <field name="tax_id" invisible="1" />
                                    <field name="wht_tax_id" invisible="1" />
                                    <field name="account_id" />
                                    <field name="amount" sum="Total" />
                                </list>
                            </field>
                        </div>
                        <group class="oe_subtotal_footer oe_right" invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')">
                            <field name="wht_pay_type" widget="selection" />
                            <field name="wht_base_amount" readonly="1" force_save="1" />
                            <field name="wht_amount" readonly="1" force_save="1" />
                            <field name="wht_net_total" class="oe_subtotal_footer_separator" readonly="1" force_save="1" />
                            <field name="amount_due" class="oe_subtotal_footer_separator" readonly="1" force_save="1" />
                        </group>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>