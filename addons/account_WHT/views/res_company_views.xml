<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_wht" model="ir.ui.view">
        <field name="name">res.company.form.inherit.wht</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Signature">
                    <group>
                        <group>
                            <field name="signature_image" widget="image" options="{'size': [0, 90]}"/>
                            <field name="signature_name"/>
                            <field name="signature_position"/>
                            <field name="wht_signer_mode"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
