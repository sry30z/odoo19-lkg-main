<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wht_export_wizard_form" model="ir.ui.view">
        <field name="name">wht.export.wizard.form</field>
        <field name="model">wht.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export WHT for e-Filing">
                <field name="state" invisible="1"/>
                <div invisible="state == 'get'">
                    <p>Select the date range and type of WHT to export the text file for Revenue Department.</p>
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="wht_type"/>
                        </group>
                    </group>
                </div>
                <div invisible="state == 'choose'">
                    <h2>Export Successful</h2>
                    <p>Here is the generated text file. Please download it and use it to upload to the Revenue Department's e-Filing system.</p>
                    <group>
                        <field name="export_filename" invisible="1"/>
                        <field name="export_file" readonly="1" filename="export_filename"/>
                    </group>
                </div>
                <footer>
                    <button name="action_export" string="Generate File" type="object" class="btn-primary" invisible="state == 'get'"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wht_export_wizard" model="ir.actions.act_window">
        <field name="name">Export WHT (PND 3/53)</field>
        <field name="res_model">wht.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_wht_export_wizard" name="Export WHT" parent="account.menu_finance_reports" action="action_wht_export_wizard" sequence="100"/>
</odoo>
